{
  "rewrites": [
    {
      "source": "/feedback",
      "destination": "/feedback.html"
    },
    {
      "source": "/contact",
      "destination": "/lead-form.html"
    },
    {
      "source": "/book",
      "destination": "/book.html"
    },
    {
      "source": "/portal",
      "destination": "/portal.html"
    },
    {
      "source": "/cleaner-portal",
      "destination": "/cleaner-portal.html"
    },
    {
      "source": "/agree",
      "destination": "/agree.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/run-automations",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/update-segments",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/run-broadcasts",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/send-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/run-job-completions",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/run-invoice-reminders",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/run-policy-reminders",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/run-review-requests",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/run-task-automations",
      "schedule": "0 18 * * *"
    }
  ]
}
